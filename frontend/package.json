{
  "name": "telebuba-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "boundaries": "steiger ./src",
    "test": "vitest run --coverage",
    "gates": "npm run boundaries && npm run lint && npm run format && npm run typecheck && npm run test",
    "gen:api": "openapi-ts && prettier --write \"src/shared/api/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-router": "^1.87.0",
    "@sentry/react": "^8.45.1",
    "clsx": "^2.1.1",
    "flag-icons": "^7.3.2",
    "@fontsource/inter": "^5.1.0",
    "@fontsource/jetbrains-mono": "^5.1.1",
    "i18next": "^24.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.2.0",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.95.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "happy-dom": "^15.11.7",
    "postcss": "^8.4.49",
    "prettier": "^3.6.2",
    "steiger": "^0.5.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
