# Telebuba environment template.
# Copy to .env and fill the required keys. Convention: nested config uses
# double-underscore (matches pydantic-settings' default delimiter).

# --- Telegram ---
TELEGRAM__API_ID=0
TELEGRAM__API_HASH=
TELEGRAM__SESSION_DIR=sessions
TELEGRAM__TIMEOUT_SECONDS=20
TELEGRAM__CONNECTION_RETRIES=3
TELEGRAM__RETRY_DELAY_SECONDS=2
TELEGRAM__REQUEST_RETRIES=3

# --- UI ---
UI__PORT=8080

# --- Database ---
DB__PATH=telebuba.db

# --- Logging ---
LOGGING__PATH=debug.log
LOGGING__LEVEL=INFO
LOGGING__ROTATION=10 MB
LOGGING__RETENTION=10
# Leave empty in dev — Sentry only activates when LOGGING__SENTRY_DSN is set.
LOGGING__SENTRY_DSN=

# --- Gemini (AI inter-account chat) ---
# Optional: a default key. The Warming page also has a UI field that overrides
# this and is persisted in the DB. Leave empty to disable AI chat.
GEMINI__API_KEY=
GEMINI__MODEL=gemini-2.5-flash
