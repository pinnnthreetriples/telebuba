# Telebuba environment template.
# Copy to `.env` and fill in secrets. Every key mirrors a field in core/config.py
# (nested pydantic-settings, one namespace per domain). Values shown are the
# in-code defaults; the test suite asserts this file stays in sync with config.
# Keys use the double-underscore convention: NAMESPACE__FIELD.

# --- Telegram (TELEGRAM__) -------------------------------------------------
TELEGRAM__API_ID=0
TELEGRAM__API_HASH=
TELEGRAM__SESSION_DIR=sessions
TELEGRAM__TIMEOUT_SECONDS=20
TELEGRAM__CONNECTION_RETRIES=3
TELEGRAM__RETRY_DELAY_SECONDS=2
TELEGRAM__REQUEST_RETRIES=3
# 0 disables Telethon's built-in auto-sleep; we handle FloodWait explicitly.
TELEGRAM__FLOOD_SLEEP_THRESHOLD=0

# --- API (API__) -----------------------------------------------------------
# 127.0.0.1 binds loopback only; set 0.0.0.0 for a container/prod deploy.
API__HOST=127.0.0.1
API__PORT=8080
# JSON list of allowed CORS origins for the SPA (dev uses the Vite proxy, so empty).
API__CORS_ORIGINS=[]
API__VERSION=v1
# SSE live-event stream tunables (GET /api/v1/events).
API__SSE_KEEPALIVE_SECONDS=15
API__SSE_MAX_QUEUE=1000

# --- Auth (AUTH__) ---------------------------------------------------------
# JWT signing secret — set a long random value before enabling login.
AUTH__SECRET=
AUTH__ALGORITHM=HS256
AUTH__COOKIE_NAME=tb_session
# Set false only for local http dev (the cookie is HttpOnly + SameSite regardless).
AUTH__COOKIE_SECURE=true
AUTH__COOKIE_SAMESITE=lax
AUTH__SESSION_TTL_MINUTES=720
# First-admin seeding (no public signup): an admin is created at startup when no
# users exist and both are set.
AUTH__ADMIN_USERNAME=
AUTH__ADMIN_PASSWORD=
AUTH__LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
AUTH__LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

# --- Database (DB__) -------------------------------------------------------
DB__PATH=telebuba.db

# --- Proxy checks (PROXY__) ------------------------------------------------
PROXY__CHECK_HOST=ip-api.com
PROXY__CHECK_PATH=/json?fields=status,message,query,country,countryCode,as
PROXY__CHECK_PORT=80
PROXY__CHECK_TIMEOUT_SECONDS=8
PROXY__DATACENTER_ASN_KEYWORDS=["amazon","aws","google","microsoft","azure","digitalocean","hetzner","ovh","linode","vultr","contabo","leaseweb","m247","choopa","oracle","scaleway"]

# --- Profile media limits (PROFILE_MEDIA__) --------------------------------
PROFILE_MEDIA__PHOTO_MAX_BYTES=10000000
PROFILE_MEDIA__STORY_IMAGE_MAX_BYTES=10000000
PROFILE_MEDIA__STORY_VIDEO_MAX_BYTES=100000000
PROFILE_MEDIA__MUSIC_MAX_BYTES=30000000
PROFILE_MEDIA__SESSION_MAX_BYTES=5000000
# In-process TTL for the live-profile snapshot the edit-profile dialog uses.
PROFILE_MEDIA__READ_SNAPSHOT_TTL_SECONDS=300
PROFILE_MEDIA__MUSIC_PREVIEW_LIMIT=50

# --- Logging (LOGGING__) ---------------------------------------------------
LOGGING__PATH=debug.log
LOGGING__LEVEL=INFO
LOGGING__ROTATION=10 MB
LOGGING__RETENTION=10
LOGGING__SENTRY_DSN=

# --- Warming engine (WARMING__) --------------------------------------------
# Per-action pacing.
WARMING__ACTION_DELAY_MIN_SECONDS=10
WARMING__ACTION_DELAY_MAX_SECONDS=30
WARMING__TYPING_MIN_SECONDS=5
WARMING__TYPING_MAX_SECONDS=30
WARMING__READING_MIN_SECONDS=8
WARMING__READING_MAX_SECONDS=45
WARMING__CYCLE_SLEEP_MIN_HOURS=12
WARMING__CYCLE_SLEEP_MAX_HOURS=30
WARMING__STARTUP_JITTER_MAX_SECONDS=8
WARMING__CHANNELS_PER_CYCLE_MIN=1
WARMING__CHANNELS_PER_CYCLE_MAX=3
WARMING__REACTION_PROBABILITY=0.6
WARMING__READ_MESSAGE_LIMIT=15
WARMING__REACTION_MESSAGE_LIMIT=20
WARMING__DEFAULT_REACTIONS=["👍","🔥","❤️","😁","🎉","👏","🤔","🙏"]
# Channel guardrails.
WARMING__MAX_CHANNELS_TOTAL=500
WARMING__MAX_CHANNELS_PER_ADD=50
WARMING__MAX_CHANNEL_LENGTH=120
WARMING__CHAT_MESSAGE_MAX_CHARS=300
WARMING__CHAT_MESSAGE_MAX_LINES=4
WARMING__STOP_CANCEL_TIMEOUT_SECONDS=5
WARMING__ENFORCE_READINESS=true
# Quiet hours (hour-of-day window in each account's local timezone; disabled by default).
WARMING__QUIET_HOURS_ENABLED=false
WARMING__QUIET_HOURS_START=0
WARMING__QUIET_HOURS_END=0
# 0 = no per-account daily action cap.
WARMING__MAX_DAILY_ACTIONS=0
# Ramp-up for young accounts.
WARMING__RAMP_ENABLED=true
WARMING__RAMP_FULL_AGE_HOURS=192
WARMING__RAMP_INITIAL_CHANNELS_MAX=1
WARMING__RAMP_INITIAL_REACTION_PROBABILITY=0.1
WARMING__DM_MIN_AGE_HOURS=36
WARMING__SPAM_STATUS_TTL_HOURS=36
# Quarantine recovery.
WARMING__QUARANTINE_HOURS=48
WARMING__QUARANTINE_MAX_REPEATS=3
# Content de-duplication / filtering.
WARMING__CONTENT_DEDUP_WINDOW_DAYS=7
WARMING__CONTENT_MAX_ATTEMPTS=3
WARMING__CONTENT_BLOCK_LINKS=true
WARMING__CONTENT_FORBIDDEN_WORDS=["реклама","купить","продам","продаю","скидк","промокод"]
# Retention windows for append-only tables (0 disables that purge).
WARMING__LOG_RETENTION_DAYS=30
WARMING__DIALOGUE_MESSAGE_RETENTION_DAYS=90
WARMING__SENT_HASH_RETENTION_DAYS=14
# Inter-account dialogue pairing.
WARMING__DIALOGUE_PARTNERS_MIN=2
WARMING__DIALOGUE_PARTNERS_MAX=4
WARMING__DIALOGUE_RESHUFFLE_DAYS=10
WARMING__DIALOGUE_MAX_TURNS=12
WARMING__DIALOGUE_CONVERSATION_WINDOW_HOURS=48
# Human-like timing: clipped log-normal inter-action pauses.
WARMING__DELAY_LOGNORM_MU=-0.8
WARMING__DELAY_LOGNORM_SIGMA=0.6
# Typing simulation.
WARMING__TYPING_SIMULATION_ENABLED=true
WARMING__TYPING_WPM=45
WARMING__TYPING_SIM_MIN_SECONDS=0.5
WARMING__TYPING_SIM_MAX_SECONDS=12
# Active local-time window (account phone timezone).
WARMING__ACTIVE_HOURS_ENABLED=true
WARMING__ACTIVE_HOURS_START=8
WARMING__ACTIVE_HOURS_END=23
# Per-card activity-log panel: how many recent log rows to show (newest-first).
WARMING__CARD_LOG_LIMIT=30

# --- Gemini (GEMINI__) -----------------------------------------------------
GEMINI__API_KEY=
GEMINI__MODEL=gemini-2.5-flash
GEMINI__BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI__TIMEOUT_SECONDS=30
GEMINI__TEMPERATURE=0.9
GEMINI__MAX_OUTPUT_TOKENS=120

# --- Trust score (TRUST__) -------------------------------------------------
# Band lower bounds (score >= bound -> that band).
TRUST__EXCELLENT_MIN=90
TRUST__GOOD_MIN=75
TRUST__WATCH_MIN=60
TRUST__AT_RISK_MIN=40
# Penalties subtracted from a 100 baseline.
TRUST__PENALTY_NOT_ALIVE=40
TRUST__PENALTY_SPAM_LIMITED=50
TRUST__PENALTY_SPAM_UNKNOWN=10
TRUST__PENALTY_QUARANTINE_EACH=15
TRUST__PENALTY_FLOOD_ACTIVE=15
TRUST__PENALTY_GEO_MISMATCH=10
TRUST__PENALTY_GEO_UNKNOWN=5
TRUST__PENALTY_PROXY_FAILED=20
TRUST__PENALTY_NEW_ACCOUNT=10
TRUST__NEW_ACCOUNT_HOURS=48

# --- Neurocomment engine (NEUROCOMMENT__) ----------------------------------
# Human-like pause before replying to a fresh post.
NEUROCOMMENT__REPLY_DELAY_MIN_SECONDS=3
NEUROCOMMENT__REPLY_DELAY_MAX_SECONDS=10
# Spacing between discussion-group joins at campaign onboarding.
NEUROCOMMENT__JOIN_DELAY_MIN_SECONDS=30
NEUROCOMMENT__JOIN_DELAY_MAX_SECONDS=60
# Per-account throughput ceiling.
NEUROCOMMENT__MAX_COMMENTS_PER_HOUR=10
# Comment length guardrail (words).
NEUROCOMMENT__COMMENT_MAX_WORDS=30
# Per-(account, channel) daily comment cap (0 = no cap).
NEUROCOMMENT__MAX_COMMENTS_PER_CHANNEL_PER_DAY=3
# Retries for a failed comment attempt before giving up.
NEUROCOMMENT__MAX_RETRIES=2
# Cross-account semantic dedup (token-set Jaccard): reject a candidate whose max
# similarity to a recent posted comment in the same channel/window reaches this
# threshold, then regenerate. 0 disables it; try ~0.8 to enable.
NEUROCOMMENT__SEMANTIC_DEDUP_THRESHOLD=0
# Look-back window (hours) for the semantic-dedup comparison set.
NEUROCOMMENT__SEMANTIC_DEDUP_WINDOW_HOURS=24
# In-memory cooldown after a PEER_FLOOD before the account is reselected.
NEUROCOMMENT__PEER_FLOOD_COOLDOWN_SECONDS=3600
# Link-stripped word-char budget below which a post is treated as link-only/ad.
NEUROCOMMENT__LINK_ONLY_MAX_WORD_CHARS=10
# Grace period to await in-flight on-post tasks on shutdown before cancelling.
NEUROCOMMENT__STOP_CANCEL_TIMEOUT_SECONDS=5
# --- Ф2: deletion sweep -> escalating channel back-off ---
# How often the sweep re-reads recent comments (0 disables the sweep).
NEUROCOMMENT__DELETION_SWEEP_INTERVAL_SECONDS=1800
# How far back the sweep re-checks posted comments for deletion.
NEUROCOMMENT__DELETION_SWEEP_LOOKBACK_HOURS=24
# Vanished comments within the window needed to trip a channel's back-off.
NEUROCOMMENT__CHANNEL_BACKOFF_MIN_DELETIONS=3
# First back-off duration; doubles per consecutive trip, capped at the max.
NEUROCOMMENT__CHANNEL_BACKOFF_BASE_SECONDS=3600
NEUROCOMMENT__CHANNEL_BACKOFF_MAX_SECONDS=86400
# Ф2 challenge solver — global opt-in flag (default off; per-campaign solver_enabled overrides).
NEUROCOMMENT__CHALLENGE_SOLVER_ENABLED=false
# Window the onboarding solver waits for a guardian-bot challenge after joining.
NEUROCOMMENT__CHALLENGE_WAIT_TIMEOUT_SECONDS=20
# Hard cutoff on the Gemini decision call.
NEUROCOMMENT__CHALLENGE_GEMINI_TIMEOUT_SECONDS=10
# Log-normal humanization pause before clicking, clamped to [min, max].
NEUROCOMMENT__CHALLENGE_CLICK_DELAY_MIN_SECONDS=3
NEUROCOMMENT__CHALLENGE_CLICK_DELAY_MAX_SECONDS=6
# Reserved for Phase-2 human-queue routing of low-confidence decisions.
NEUROCOMMENT__CHALLENGE_MIN_CONFIDENCE=0.7
# Ф2 channel challenge back-off: K consecutive solver failures trip an escalating cooldown.
NEUROCOMMENT__CHANNEL_CHALLENGE_BACKOFF_MIN_FAILURES=3
NEUROCOMMENT__CHANNEL_CHALLENGE_BACKOFF_BASE_SECONDS=3600
NEUROCOMMENT__CHANNEL_CHALLENGE_BACKOFF_MAX_SECONDS=86400
# Min warming age (days) for an account to show as "warmed" in the neurocomment page.
NEUROCOMMENT__WARMED_MIN_DAYS=14
# Rows in the engine panel's collapsible neurocomment-activity log.
NEUROCOMMENT__LOG_LIMIT=50
